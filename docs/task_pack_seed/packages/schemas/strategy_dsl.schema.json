{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RestrictedStrategyDSL",
  "type": "object",
  "required": [
    "name",
    "asset_class",
    "universe",
    "timeframe",
    "rebalance_frequency",
    "signals",
    "portfolio",
    "cost_model",
    "slippage_model",
    "risk"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "asset_class": {
      "type": "string",
      "enum": [
        "stock",
        "equity_etf"
      ]
    },
    "universe": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z.]{1,10}$"
      },
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true
    },
    "timeframe": {
      "type": "string",
      "enum": [
        "1d"
      ]
    },
    "rebalance_frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekly",
        "monthly",
        "quarterly"
      ]
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "momentum",
              "moving_average_cross",
              "volatility_filter",
              "rebalance_fixed_weight"
            ]
          },
          "lookback_days": {
            "type": "integer",
            "minimum": 2,
            "maximum": 756
          },
          "rank_descending": {
            "type": "boolean"
          },
          "short_window": {
            "type": "integer",
            "minimum": 2,
            "maximum": 252
          },
          "long_window": {
            "type": "integer",
            "minimum": 5,
            "maximum": 756
          },
          "max_volatility": {
            "type": "number",
            "minimum": 0,
            "maximum": 2
          }
        }
      }
    },
    "portfolio": {
      "type": "object",
      "required": [
        "max_positions",
        "max_weight_per_asset",
        "cash_if_no_signal"
      ],
      "additionalProperties": false,
      "properties": {
        "max_positions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "max_weight_per_asset": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "cash_if_no_signal": {
          "type": "boolean"
        }
      }
    },
    "cost_model": {
      "type": "object",
      "required": [
        "commission_bps",
        "spread_bps"
      ],
      "additionalProperties": false,
      "properties": {
        "commission_bps": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "spread_bps": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "slippage_model": {
      "type": "object",
      "required": [
        "slippage_bps"
      ],
      "additionalProperties": false,
      "properties": {
        "slippage_bps": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "no_leverage",
        "no_short",
        "max_drawdown_pct"
      ],
      "additionalProperties": false,
      "properties": {
        "no_leverage": {
          "const": true
        },
        "no_short": {
          "const": true
        },
        "max_drawdown_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 50
        }
      }
    }
  }
}
